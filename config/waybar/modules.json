{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  // Updates Count
  "custom/updates": {
    "format": "’å▓  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.local/bin/update-check",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "ghostty --class=local.floating -e ~/.local/bin/update-perform"
  },

  // Hypridle
  "custom/hypridle": {
    "format": "’ĆŻ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle"
  },

  // Clock
  "clock": {
    "format": "{:%A %H:%M}",
    "format-alt": "{:%d %B %Y}",
    "tooltip": false
  },

  // CPU
  "cpu": {
    "interval": 5,
    "format": "’ŗø",
    "on-click": "ghostty -e btop"
  },

  // Pulseaudio
  "pulseaudio": {
    "scroll-step": 1, 
    "format": "{icon}",
    "on-click": "ghostty --class=local.wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "format-muted": "Ņ╗©",
    "format-icons": {
      "default": ["’Ć¦", "’Ć©"]
    }
  },

  // Bluetooth
  "bluetooth": {
    "format": "’Ŗō",
    "format-disabled": "¾░é▓",
    "format-connected": "’Ŗö",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "ghostty --class=local.bluetui -e bluetui"
  },
  
  // Battery
  "battery": {
  "format": "{capacity}% {icon}",
  "format-discharging": "{icon}",
  "format-charging": "{icon}",
  "format-plugged": "’ć”",
  "format-icons": {
    "charging": ["¾░ó£", "¾░éå", "¾░éć", "¾░éł", "¾░óØ", "¾░éē", "¾░ó×", "¾░éŖ", "¾░éŗ", "¾░éģ"],
    "default": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"]
  },
  "format-full": "¾░éģ",
  "tooltip-format-discharging": "{power:>1.0f}WŌåō {capacity}%",
  "tooltip-format-charging": "{power:>1.0f}WŌåæ {capacity}%",
  "interval": 5,
  "states": {
    "warning": 20,
    "critical": 10
     }
  },

  // Network
  "network": {
  "format-icons": ["¾░ż»", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"],
  "format": "{icon}",
  "format-wifi": "{icon}",
  "format-ethernet": "¾░Ćé",
  "format-disconnected": "¾░ż«",
  "tooltip-format-wifi": "{essid} ({frequency} GHz)\nŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
  "tooltip-format-ethernet": "ŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
  "tooltip-format-disconnected": "Disconnected",
  "interval": 3,
  "spacing": 1,
  "on-click": "ghostty --class=local.impala -e impala"
  }
}
