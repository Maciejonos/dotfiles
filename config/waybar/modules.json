{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  // Updates Count
  "custom/updates": {
    "format": "οÜ≤  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.local/bin/update-check",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "ghostty --class=local.floating -e ~/.local/bin/update-perform"
  },

  // Hypridle
  "custom/hypridle": {
    "format": "οÄΘ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle"
  },

  // Clock
  "clock": {
    "format": "{:%A %H:%M}",
    "format-alt": "{:%d %B %Y}",
    "tooltip": false
  },

  // CPU
  "cpu": {
    "interval": 5,
    "format": "ο΄¦",
    "on-click": "ghostty -e btop"
  },

  // Pulseaudio
  "pulseaudio": {
    "scroll-step": 1, 
    "format": "{icon}",
    "on-click": "ghostty --class=local.wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "format-muted": "νΜ®",
    "format-icons": {
      "default": ["οÄß", "οÄ®"]
    }
  },

  // Bluetooth
  "bluetooth": {
    "format": "οäî",
    "format-disabled": "σΑ²≤",
    "format-connected": "οäî",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "ghostty --class=local.bluetui -e bluetui"
  },
  
  // Battery
  "battery": {
  "format": "{capacity}% {icon}",
  "format-discharging": "{icon}",
  "format-charging": "{icon}",
  "format-plugged": "ο΅Π",
  "format-icons": {
    "charging": ["σΑΔ€", "σΑ²Ü", "σΑ²΅", "σΑ²à", "σΑΔù", "σΑ²â", "σΑΔû", "σΑ²ä", "σΑ²΄", "σΑ²Ö"],
    "default": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
  },
  "format-full": "σΑ²Ö",
  "tooltip-format-discharging": "{power:>1.0f}WβÜ™ {capacity}%",
  "tooltip-format-charging": "{power:>1.0f}WβÜë {capacity}%",
  "interval": 5,
  "states": {
    "warning": 20,
    "critical": 10
     }
  },

  // Network
  "network": {
  "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
  "format": "{icon}",
  "format-wifi": "{icon}",
  "format-ethernet": "σΑÄ²",
  "format-disconnected": "σΑΛ°",
  "tooltip-format-wifi": "{essid} ({frequency} GHz)\nβ΅Θ{bandwidthDownBytes}  β΅Γ{bandwidthUpBytes}",
  "tooltip-format-ethernet": "β΅Θ{bandwidthDownBytes}  β΅Γ{bandwidthUpBytes}",
  "tooltip-format-disconnected": "Disconnected",
  "interval": 3,
  "spacing": 1,
  "on-click": "ghostty --class=local.impala -e impala"
  },

  // Quicklinks
  "custom/brightness": {
    "format": "ο΅û",
    "on-click": "~/.local/bin/ddc-brightness-popup"
  },
  "custom/filemanager": {
    "format": "ο¹Φ",
    "on-click": "nautilus",
    "tooltip-format": "Open Filemanager"
  },
  "custom/openwebui": {
    "format": "οï³",
    "on-click": "~/.local/bin/launch-webapp http://localhost:8080",
    "tooltip-format": "OpenWebUI"
  }
}
