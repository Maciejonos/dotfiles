#!/bin/bash
set -e

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)
source "$SCRIPT_DIR/lib/helpers.sh"

DOTFILES_DIR="$HOME/.config/dotfiles"

# Copy monitors.conf
if [ -f "$DOTFILES_DIR/templates/hypr/conf/monitors.conf" ]; then
  if [ ! -f "$HOME/.config/hypr/conf/monitors.conf" ]; then
    cp "$DOTFILES_DIR/templates/hypr/conf/monitors.conf" "$HOME/.config/hypr/conf/monitors.conf"
    log_success "Copied monitors.conf"
  else
    log_detail "monitors.conf already exists, skipping"
  fi
fi

# Copy ly configuration
log_info "Configuring ly display manager..."
if pacman -Q ly &>/dev/null; then
  # Copy systemd override (TTY colors)
  sudo mkdir -p /etc/systemd/system/ly.service.d
  sudo cp "$DOTFILES_DIR/templates/ly/override.conf" /etc/systemd/system/ly.service.d/override.conf
  sudo systemctl daemon-reload
  log_detail "Copied ly systemd override"

  # Copy ly config.ini
  if [ -f /etc/ly/config.ini ]; then
    sudo rm /etc/ly/config.ini
  fi
  sudo cp "$DOTFILES_DIR/templates/ly/config.ini" /etc/ly/config.ini
  log_success "Copied ly configuration"
else
  log_detail "ly not installed, skipping ly configuration"
fi

# Copy .zshrc
log_info "Copying .zshrc config..."
if [ -e "$HOME/.zshrc" ]; then
  rm -rf "$HOME/.zshrc"
fi
cp "$DOTFILES_DIR/templates/config/.zshrc" "$HOME/.zshrc"
log_success "Copied .zshrc"

# Copy waybar quicklinks.json
if [ -f "$DOTFILES_DIR/templates/config/waybar/quicklinks.json" ]; then
  if [ ! -f "$HOME/.config/waybar/quicklinks.json" ]; then
    mkdir -p "$HOME/.config/waybar"
    cp "$DOTFILES_DIR/templates/config/waybar/quicklinks.json" "$HOME/.config/waybar/quicklinks.json"
    log_success "Copied waybar quicklinks.json"
  else
    log_detail "quicklinks.json already exists, skipping"
  fi
fi

# Copy GTK settings.ini files
if [ -f "$DOTFILES_DIR/templates/config/gtk-3.0/settings.ini" ]; then
  if [ ! -f "$HOME/.config/gtk-3.0/settings.ini" ]; then
    mkdir -p "$HOME/.config/gtk-3.0"
    cp "$DOTFILES_DIR/templates/config/gtk-3.0/settings.ini" "$HOME/.config/gtk-3.0/settings.ini"
    log_success "Copied GTK-3.0 settings"
  else
    log_detail "GTK-3.0 settings.ini already exists, skipping"
  fi
fi

if [ -f "$DOTFILES_DIR/templates/config/gtk-4.0/settings.ini" ]; then
  if [ ! -f "$HOME/.config/gtk-4.0/settings.ini" ]; then
    mkdir -p "$HOME/.config/gtk-4.0"
    cp "$DOTFILES_DIR/templates/config/gtk-4.0/settings.ini" "$HOME/.config/gtk-4.0/settings.ini"
    log_success "Copied GTK-4.0 settings"
  else
    log_detail "GTK-4.0 settings.ini already exists, skipping"
  fi
fi

# Copy chromium Preferences
if [ -f "$DOTFILES_DIR/templates/config/chromium/Default/Preferences" ]; then
  if [ ! -f "$HOME/.config/chromium/Default/Preferences" ]; then
    mkdir -p "$HOME/.config/chromium/Default"
    cp "$DOTFILES_DIR/templates/config/chromium/Default/Preferences" "$HOME/.config/chromium/Default/Preferences"
    log_success "Copied chromium Preferences"
  else
    log_detail "chromium Preferences already exists, skipping"
  fi
fi
log_success "Templates copied successfully!"
