#!/bin/bash
set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/lib/helpers.sh"
DOTFILES_DIR="$HOME/.config/dotfiles"

# Clone LazyVim starter
log_info "Cloning LazyVim starter..."
if [ -d "$HOME/.config/nvim" ]; then
  log_info "Existing nvim config found, removing..."
  rm -rf "$HOME/.config/nvim"
fi

git clone https://github.com/LazyVim/starter ~/.config/nvim
rm -rf ~/.config/nvim/.git
log_success "LazyVim starter cloned"

# Copy custom configs from templates
log_info "Copying custom LazyVim configs..."
# Note: theme.lua will be created by symlinks script for theme switching
cp "$DOTFILES_DIR/templates/nvim/lua/plugins/snacks-animated-scrolling-off.lua" "$HOME/.config/nvim/lua/plugins/"
mkdir -p "$HOME/.config/nvim/plugin/after"
cp "$DOTFILES_DIR/templates/nvim/plugin/after/transparency.lua" "$HOME/.config/nvim/plugin/after/transparency.lua"
cp "$DOTFILES_DIR/templates/nvim/lazyvim.json" "$HOME/.config/nvim/lazyvim.json"
log_success "Custom configs copied"

# Disable relative numbers
log_info "Configuring options..."
echo "vim.opt.relativenumber = false" >> "$HOME/.config/nvim/lua/config/options.lua"
log_success "LazyVim setup complete!"
