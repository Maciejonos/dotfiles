#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/lib/helpers.sh"
DOTFILES_DIR="$HOME/.config/dotfiles"

# Symlink applications folder
if [ -e "$HOME/.local/share/applications" ]; then
    rm -rf "$HOME/.local/share/applications"
fi
mkdir -p "$HOME/.local/share"
ln -snf "$DOTFILES_DIR/applications" "$HOME/.local/share/applications"
log_success "Linked applications"

# Symlink bin folder
if [ -e "$HOME/.local/bin" ]; then
    rm -rf "$HOME/.local/bin"
fi
mkdir -p "$HOME/.local"
ln -snf "$DOTFILES_DIR/bin" "$HOME/.local/bin"
log_success "Linked bin"

# Symlink all config folders
log_info "Linking config folders..."
for item in "$DOTFILES_DIR/config"/*; do
    name=$(basename "$item")

    target="$HOME/.config/$name"
    if [ -e "$target" ]; then
        rm -rf "$target"
    fi
    ln -snf "$item" "$target"
    log_detail "$name"
done

# Detect GPU and symlinks env
log_info "Detecting GPU configuration..."
if lspci | grep -i nvidia &>/dev/null; then
  log_detail "NVIDIA GPU detected, using NVIDIA env config"
  ln -snf "$DOTFILES_DIR/profiles/nvidia/env.conf" "$HOME/.config/hypr/conf/environments.conf"
  log_success "Hyprland environments linked (nvidia)"
else
  log_detail "No NVIDIA GPU detected, using standard env config"
  ln -snf "$DOTFILES_DIR/profiles/general/env.conf" "$HOME/.config/hypr/conf/environments.conf"
  log_success "Hyprland environments linked"
fi

# Symlink keybindings based on hardware detection
log_info "Detecting hardware for keybindings..."
if ls /sys/class/power_supply/BAT* >/dev/null 2>&1 || [ -d /sys/class/power_supply/battery ]; then
    log_detail "Laptop detected, using laptop keybindings"
    spinner "Installing brightnessctl..." paru --noconfirm -S brightnessctl
    log_success "brightnessctl installed"
    ln -snf "$DOTFILES_DIR/profiles/laptop/keybindings.conf" "$HOME/.config/hypr/conf/keybindings.conf"
else
    log_detail "Desktop detected, using desktop keybindings"
    log_info "Installing ddcutil..."
    spinner "Installing ddcutil..." paru --noconfirm -S ddcutil
    log_success "ddcutil installed"
    ln -snf "$DOTFILES_DIR/profiles/desktop/keybindings.conf" "$HOME/.config/hypr/conf/keybindings.conf"
fi
log_success "Linked keybindings"

# Set initial theme
log_info "Setting up initial theme (everforest)..."
mkdir -p "$DOTFILES_DIR/current"
ln -snf "$DOTFILES_DIR/themes/everforest" "$DOTFILES_DIR/current/theme"
ln -snf "$DOTFILES_DIR/current/theme/backgrounds/1-everforest.jpg" "$DOTFILES_DIR/current/background"
ln -snf "$DOTFILES_DIR/current/theme/neovim.lua" "$HOME/.config/nvim/lua/plugins/theme.lua"
ln -snf "$DOTFILES_DIR/current/theme/btop.theme" "$HOME/.config/btop/themes/current.theme"
ln -snf "$DOTFILES_DIR/current/theme/mako.ini" "$HOME/.config/mako/config"
ln -snf "$DOTFILES_DIR/current/theme/eza.yml" "$HOME/.config/eza/theme.yml"

gsettings set org.gnome.desktop.interface icon-theme "Yaru-sage"
gsettings set org.gnome.desktop.interface font-name 'CaskaydiaMono Nerd Font Mono 11'
gsettings set org.gnome.desktop.interface monospace-font-name 'CaskaydiaMono Nerd Font Mono 11'

log_success "Initial theme set (everforest)"
log_success "All symlinks created!"