#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Ensure the dotfiles folder is in the correct location
EXPECTED_PATH="$HOME/.config/dotfiles/install"
if [[ "$SCRIPT_DIR" != "$EXPECTED_PATH" ]]; then
    echo "ERROR: This script must be run from $EXPECTED_PATH"
    echo "Current location: $SCRIPT_DIR"
    echo ""
    echo "Please move the dotfiles folder to ~/.config/dotfiles and try again"
    exit 1
fi

# Source helpers
source "$SCRIPT_DIR/lib/helpers.sh"

# Ensure gum is installed first
ensure_gum

_isInstalled() {
    package="$1"
    check="$(sudo pacman -Qs --color always "${package}" | grep "local" | grep "${package} ")"
    if [ -n "${check}" ]; then
        echo 0
        return
    fi
    echo 1
    return
}

_installParu() {
    if [[ ! $(_isInstalled "base-devel") == 0 ]]; then
        log_info "Installing base-devel..."
        sudo pacman --noconfirm -S base-devel
    fi
    if [[ ! $(_isInstalled "git") == 0 ]]; then
        log_info "Installing git..."
        sudo pacman --noconfirm -S git
    fi

    log_info "Cloning paru from AUR..."
    git clone https://aur.archlinux.org/paru.git /tmp/paru
    cd /tmp/paru
    log_info "Building and installing paru (this may take a moment)..."
    makepkg -si --noconfirm
    cd ~
    rm -rf /tmp/paru
    log_success "Paru installed successfully"
}

_installPackages() {
    local total=$(grep -v '^#' "$1" | grep -v '^$' | wc -l)
    local current=0

    while IFS= read -r pkg || [ -n "$pkg" ]; do
        [[ -z "$pkg" || "$pkg" =~ ^# ]] && continue

        current=$((current + 1))

        if [[ $(_isInstalled "${pkg}") == 0 ]]; then
            log_progress "$pkg (already installed)" "$current/$total"
            continue
        fi

        spinner "Installing $pkg... [$current/$total]" paru --noconfirm -S "${pkg}"
        log_success "$pkg"
    done < "$1"
}

clear
log_header "Dotfiles Installation"

START_TIME=$(date +%s)

if [[ ! $(_isInstalled "paru") == 0 ]]; then
    log_step "Installing paru AUR helper"
    _installParu
fi

log_step "Installing packages"
_installPackages "$SCRIPT_DIR/pkgs.txt"

log_step "Installing Flatpak applications"
bash "$SCRIPT_DIR/flatpak"

log_step "Installing zsh plugins"
bash "$SCRIPT_DIR/zsh-setup"

log_step "Setting up LazyVim"
bash "$SCRIPT_DIR/lazyvim-setup"

log_step "Creating symlinks"
bash "$SCRIPT_DIR/symlinks"

log_step "Configuring system"
bash "$SCRIPT_DIR/system-setup"

log_step "Copying template files"
bash "$SCRIPT_DIR/copy-templates"

END_TIME=$(date +%s)
TOTAL_TIME=$((END_TIME - START_TIME))
MINUTES=$((TOTAL_TIME / 60))
SECONDS=$((TOTAL_TIME % 60))

clear
log_header "Installation Complete!"
echo
log_success "Installed in ${MINUTES}m ${SECONDS}s"
echo
log_info "Please reboot for all changes to take effect"
echo

if ask_yes_no "Reboot now?"; then
    clear
    systemctl reboot --no-wall 2>/dev/null || reboot 2>/dev/null
fi
