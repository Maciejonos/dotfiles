#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Ensure the dotfiles folder is in the correct location
EXPECTED_PATH="$HOME/.config/dotfiles/install"
if [[ "$SCRIPT_DIR" != "$EXPECTED_PATH" ]]; then
    echo "ERROR: This script must be run from $EXPECTED_PATH"
    echo "Current location: $SCRIPT_DIR"
    echo ""
    echo "Please move the dotfiles folder to ~/.config/dotfiles and try again"
    exit 1
fi

# Source helpers (will work even if gum not installed yet)
source "$SCRIPT_DIR/lib/helpers.sh"

# Ensure gum is installed first for better UI
ensure_gum

_isInstalled() {
    package="$1"
    check="$(sudo pacman -Qs --color always "${package}" | grep "local" | grep "${package} ")"
    if [ -n "${check}" ]; then
        echo 0
        return
    fi
    echo 1
    return
}

_installParu() {
    if [[ ! $(_isInstalled "base-devel") == 0 ]]; then
        log_info "Installing base-devel..."
        sudo pacman --noconfirm -S base-devel
        log_success "base-devel installed"
    fi
    if [[ ! $(_isInstalled "git") == 0 ]]; then
        log_info "Installing git..."
        sudo pacman --noconfirm -S git
        log_success "git installed"
    fi

    log_info "Cloning paru from AUR..."
    git clone https://aur.archlinux.org/paru.git /tmp/paru
    cd /tmp/paru
    log_info "Building and installing paru (this may take a moment)..."
    makepkg -si --noconfirm
    cd ~
    rm -rf /tmp/paru
    log_success "Paru installed successfully"
}

_installPackages() {
    local total=$(grep -v '^#' "$1" | grep -v '^$' | wc -l)
    local current=0

    while IFS= read -r pkg || [ -n "$pkg" ]; do
        [[ -z "$pkg" || "$pkg" =~ ^# ]] && continue

        current=$((current + 1))

        if [[ $(_isInstalled "${pkg}") == 0 ]]; then
            log_progress "$pkg (already installed)" "$current/$total"
            continue
        fi

        spinner "Installing $pkg... [$current/$total]" paru --noconfirm -S "${pkg}"
        log_success "$pkg"
    done < "$1"
}

clear
log_header "Dotfiles Installation"

START_TIME=$(date +%s)

if [[ ! $(_isInstalled "paru") == 0 ]]; then
    log_step "Installing paru AUR helper"
    _installParu
fi

log_step "Installing packages"
_installPackages "$SCRIPT_DIR/pkgs.txt"

log_step "Installing Flatpak applications"
bash "$SCRIPT_DIR/flatpak-apps"

# Auto-detect laptop/desktop based on battery presence
BRIGHTNESS_MODE=""
if ls /sys/class/power_supply/BAT* >/dev/null 2>&1 || [ -d /sys/class/power_supply/battery ]; then
    log_info "Laptop detected (battery found), installing brightnessctl..."
    spinner "Installing brightnessctl..." paru --noconfirm -S brightnessctl
    log_success "brightnessctl installed"
    BRIGHTNESS_MODE="laptop"
else
    log_info "Desktop detected (no battery found), installing ddcutil..."
    spinner "Installing ddcutil..." paru --noconfirm -S ddcutil
    log_success "ddcutil installed"
    BRIGHTNESS_MODE="desktop"
fi

log_step "Installing zsh plugins"
bash "$SCRIPT_DIR/zsh-plugins"

log_step "Creating symlinks"
bash "$SCRIPT_DIR/symlinks"

# Copy keybindings after symlinks are created
if [ "$BRIGHTNESS_MODE" = "laptop" ]; then
    if [ -f "$SCRIPT_DIR/../static/hypr/conf/keybindings-laptop.conf" ]; then
        cp "$SCRIPT_DIR/../static/hypr/conf/keybindings-laptop.conf" "$HOME/.config/hypr/conf/keybindings.conf"
        log_success "Copied laptop keybindings"
    fi
elif [ "$BRIGHTNESS_MODE" = "desktop" ]; then
    if [ -f "$SCRIPT_DIR/../static/hypr/conf/keybindings.conf" ]; then
        cp "$SCRIPT_DIR/../static/hypr/conf/keybindings.conf" "$HOME/.config/hypr/conf/keybindings.conf"
        log_success "Copied desktop keybindings"
    fi
fi

log_step "Configuring system"
bash "$SCRIPT_DIR/system-setup"

log_step "Copying static files"
bash "$SCRIPT_DIR/static-files"

log_step "Setting GTK font"
gsettings set org.gnome.desktop.interface font-name 'CaskaydiaMono Nerd Font Mono 11'
gsettings set org.gnome.desktop.interface monospace-font-name 'CaskaydiaMono Nerd Font Mono 11'
log_success "GTK font configured"

# Detect and configure NVIDIA if present
log_step "Checking for NVIDIA GPU"
if lspci | grep -i nvidia &> /dev/null; then
    log_info "NVIDIA GPU detected, configuring for Hyprland..."
    bash "$SCRIPT_DIR/nvidia-setup"
else
    log_info "No NVIDIA GPU detected, skipping NVIDIA setup"
fi

END_TIME=$(date +%s)
TOTAL_TIME=$((END_TIME - START_TIME))
MINUTES=$((TOTAL_TIME / 60))
SECONDS=$((TOTAL_TIME % 60))

clear
log_header "Installation Complete!"
echo
log_success "Installed in ${MINUTES}m ${SECONDS}s"
echo
log_info "Please log out and back in for all changes to take effect"
echo

if ask_yes_no "Reboot now?"; then
    clear
    systemctl reboot --no-wall 2>/dev/null || reboot 2>/dev/null
fi
