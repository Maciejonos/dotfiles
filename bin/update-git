#!/bin/bash
source "$HOME/.config/dotfiles/bin/lib/helpers.sh"

DOTFILES_DIR="$HOME/.config/dotfiles"

# Get remote tag
latest_tag=$(git -C "$DOTFILES_DIR" ls-remote --tags origin | grep -v "{}" | awk '{print $2}' | sed 's#refs/tags/##' | sort -V | tail -n 1)
if [[ -z "$latest_tag" ]]; then
  log_error "Could not retrieve latest tag."
  exit 1
fi

# Get local tag
current_tag=$(git -C "$DOTFILES_DIR" describe --tags $(git -C "$DOTFILES_DIR" rev-list --tags --max-count=1) 2>/dev/null)
if [[ -z "$current_tag" ]]; then
  log_error "Could not retrieve current tag."
  exit 1
fi

# Compare versions
if [[ "$current_tag" != "$latest_tag" ]]; then
  log_success "Dotfiles update available ($latest_tag)"

  # Pull with autostash, then check for conflicts
  git -C "$DOTFILES_DIR" pull --autostash
  git -C "$DOTFILES_DIR" diff --check || git -C "$DOTFILES_DIR" reset --merge

  exit 0
else
  log_info "Dotfiles are up to date ($current_tag)"
  exit 1
fi
