#!/bin/bash
source "$HOME/.config/dotfiles/bin/lib/helpers.sh"

DOTFILES_DIR="$HOME/.config/dotfiles"

# Fetch remote changes
git -C "$DOTFILES_DIR" fetch origin --quiet

# Get current local commit
local_commit=$(git -C "$DOTFILES_DIR" rev-parse HEAD)
if [[ -z "$local_commit" ]]; then
  log_error "Could not retrieve local commit"
  exit 1
fi

# Get remote commit
remote_commit=$(git -C "$DOTFILES_DIR" rev-parse origin/$(git -C "$DOTFILES_DIR" branch --show-current))
if [[ -z "$remote_commit" ]]; then
  log_error "Could not retrieve remote commit"
  exit 1
fi

# Get short versions for display
local_short=$(echo "$local_commit" | cut -c1-7)
remote_short=$(echo "$remote_commit" | cut -c1-7)

# Compare commits
if [[ "$local_commit" != "$remote_commit" ]]; then
  log_success "Dotfiles update available ($remote_short)"
  log_info "Pulling changes..."

  # Pull with autostash, then check for conflicts
  git -C "$DOTFILES_DIR" pull --autostash
  git -C "$DOTFILES_DIR" diff --check || git -C "$DOTFILES_DIR" reset --merge

  exit 0
else
  log_info "Dotfiles are up to date ($local_short)"
  exit 1
fi
