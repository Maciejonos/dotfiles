#!/bin/bash
set -e

echo "PostgreSQL Setup Script for Arch Linux"

# Check if running as root
if [ "$EUID" -eq 0 ]; then
  echo "Error: Don't run this script as root/sudo"
  exit 1
fi

# Install PostgreSQL
echo "Installing PostgreSQL..."
sudo pacman -S --needed postgresql

# Initialize the database cluster
echo "Initializing database cluster..."
if [ ! -d "/var/lib/postgres/data/PG_VERSION" ]; then
  sudo -u postgres initdb -D /var/lib/postgres/data \
    --locale=C.UTF-8 \
    --auth-local=peer \
    --auth-host=scram-sha-256
else
  echo "Database cluster already exists, skipping initialization"
fi

# Enable and start PostgreSQL service
echo "Enabling and starting PostgreSQL service..."
sudo systemctl enable postgresql
sudo systemctl start postgresql

# Test connection
echo "Testing connection..."
if sudo -u postgres psql -c '\l' &>/dev/null; then
  echo "PostgreSQL is running and accessible"
else
  echo "Warning: Could not connect to PostgreSQL"
fi

# Install Beekeeper Studio
echo "Installing Beekeeper Studio..."
if ! command -v paru &>/dev/null; then
  echo "Warning: paru not installed, skipping Beekeeper Studio"
else
  if paru -S --needed beekeeper-studio-bin 2>/dev/null; then
    echo "Beekeeper Studio installed"
  else
    echo "Warning: Could not install Beekeeper Studio"
    echo "Install manually: paru -S beekeeper-studio-bin"
  fi
fi

echo "PostgreSQL setup completed successfully!"
