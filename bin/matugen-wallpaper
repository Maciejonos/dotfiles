#!/bin/bash

CACHE_DIR="$HOME/.cache/matugen-wallpaper"
CACHE_FILE="$CACHE_DIR/current_wallpaper"
WALLPAPER_DIR="$HOME/.config/dotfiles/themes/current/backgrounds"
CURRENT_BACKGROUND_LINK="$HOME/.config/dotfiles/current/background"

mkdir -p "$CACHE_DIR"

if [ -n "$1" ]; then
  WALLPAPER="$1"
elif [ -f "$CACHE_FILE" ]; then
  WALLPAPER=$(cat "$CACHE_FILE")
else
  echo "No wallpaper specified and no cached wallpaper found"
  exit 1
fi

if [ ! -f "$WALLPAPER" ]; then
  echo "Wallpaper file not found: $WALLPAPER"
  exit 1
fi

echo "$WALLPAPER" >"$CACHE_FILE"

# Update the current background symlink
ln -nsf "$WALLPAPER" "$CURRENT_BACKGROUND_LINK"

echo "Using wallpaper: $WALLPAPER"
echo "Running matugen..."
$HOME/.local/bin/matugen image "$WALLPAPER" -m "dark"

echo "Reloading applications..."
sleep 0.5

# Waybar
restart-app waybar

# SwayOSD
restart-app swayosd-server

# Hyprland
hyprctl reload

# btop
pkill -SIGUSR2 btop

# Mako
makoctl reload

# Ghostty
killall -SIGUSR2 ghostty

# Eza theme
theme-set-eza

# VSCode theme
theme-set-vscode

echo "Done! Theme applied."
